{
  "crons": [
    {
      "path": "/api/fetch-and-send",
      "schedule": "0 11 * * 1-5"
    },
    {
      "path": "/api/send-weekly",
      "schedule": "30 13 * * 6"
    }
  ],
  "functions": {
    "api/fetch-and-send.js": {
      "maxDuration": 60
    },
    "api/send-weekly.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
