{
  "crons": [
    {
      "path": "/api/fetch-and-send",
      "schedule": "0 23 * * 1-5"
    },
    {
      "path": "/api/send-weekly",
      "schedule": "0 14 * * 6"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
